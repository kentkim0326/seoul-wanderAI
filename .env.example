# ──────────────────────────────────────────
# Seoul Wander — Environment Variables
# ──────────────────────────────────────────
# 1. 이 파일을 .env.local 로 복사하세요
#    cp .env.example .env.local
#
# 2. 아래 값을 실제 키로 채우세요
# ──────────────────────────────────────────

# OpenAI API Key (GPT-4o 코스 생성)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# 서울 열린데이터광장 API Key (공공데이터)
# https://data.seoul.go.kr → 마이페이지 → 인증키 발급
VITE_SEOUL_API_KEY=your-seoul-opendata-key-here

# Vercel 배포 시에는 Dashboard > Settings > Environment Variables 에서 설정
# OPENAI_API_KEY 는 서버 사이드 전용 (VITE_ 접두사 없음 — 클라이언트에 노출 금지!)
